[Unit]
Description=City Pop Pi-Tail deck
After=network-online.target nginx.service
Wants=network-online.target nginx.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/city-pop
ExecStart=/opt/city-pop/.venv/bin/gunicorn --workers 1 --worker-class gthread --threads 12 --bind 127.0.0.1:18080 --timeout 0 --access-logfile - --error-logfile - citypop.app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
